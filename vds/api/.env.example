# ============================================
# BioArchive API - Ortam Degiskenleri
# ============================================
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun:
#   cp .env.example .env
#
# ONEMLI: Production ortaminda JWT_SECRET, JWT_REFRESH_SECRET,
# DB_PASSWORD ve CORS_ORIGIN degerleri ZORUNLUDUR.
# Bu degerler eksik olursa uygulama baslamaz!

# ---- Sunucu ----
NODE_ENV=production
PORT=3000
API_URL=https://api.bioarchive.com.tr

# ---- Veritabani (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bioarchive
DB_USER=bioarchive_user
DB_PASSWORD=GUCLU_BIR_SIFRE_BELIRLEYIN    # Production'da zorunlu!
DB_SSL=false

# ---- JWT (Kimlik Dogrulama) ----
# Guvenli rastgele anahtar olusturmak icin:
#   openssl rand -base64 48
JWT_SECRET=en_az_32_karakter_uzunlugunda_rastgele_bir_anahtar     # Production'da zorunlu!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=baska_bir_rastgele_anahtar_en_az_32_karakter   # Production'da zorunlu!
JWT_REFRESH_EXPIRES_IN=30d

# ---- AI Servisi ----
# Desteklenen saglayicilar: openai, anthropic
AI_PROVIDER=openai

# OpenAI ayarlari
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic ayarlari (AI_PROVIDER=anthropic yaparsaniz)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- CORS (Izin Verilen Originler) ----
CORS_ORIGIN=https://bioarchive.com.tr,https://www.bioarchive.com.tr   # Production'da zorunlu!

# ---- Dosya Yukleme ----
UPLOAD_MAX_SIZE=10485760    # 10MB (byte cinsinden)
UPLOAD_DIR=./uploads

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW=900000    # 15 dakika (milisaniye)
RATE_LIMIT_MAX=100          # Pencere basina max istek
