# ============================================
# BioArchive API - Ortam Degiskenleri
# ============================================
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun
# cp .env.example .env

# ---- Sunucu ----
NODE_ENV=production
PORT=3000
API_URL=https://api.bioarchive.com.tr

# ---- Veritabani (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bioarchive
DB_USER=bioarchive_user
DB_PASSWORD=GUCLU_BIR_SIFRE_BELIRLEYIN
DB_SSL=false

# ---- JWT (Kimlik Dogrulama) ----
JWT_SECRET=en_az_32_karakter_uzunlugunda_rastgele_bir_anahtar
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=baska_bir_rastgele_anahtar_en_az_32_karakter
JWT_REFRESH_EXPIRES_IN=30d

# ---- AI Servisi (OpenAI veya Anthropic) ----
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic kullanmak isterseniz:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- CORS ----
CORS_ORIGIN=https://bioarchive.com.tr,https://www.bioarchive.com.tr

# ---- Dosya Yukleme ----
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ---- Loglama ----
LOG_LEVEL=info
