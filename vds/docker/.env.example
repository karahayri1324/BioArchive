# ============================================
# Docker Compose - Ortam Degiskenleri
# ============================================
# Bu dosyayi .env olarak kopyalayin: cp .env.example .env
# Tum degerleri production icin uygun sekilde degistirin!
#
# Guvenli rastgele anahtar olusturmak icin:
#   openssl rand -base64 48

# Veritabani sifresi (ZORUNLU - degistirin!)
DB_PASSWORD=

# JWT anahtarlari (ZORUNLU - degistirin!)
JWT_SECRET=
JWT_REFRESH_SECRET=

# AI ayarlari
AI_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# CORS ayarlari
CORS_ORIGIN=https://bioarchive.com.tr,https://www.bioarchive.com.tr
